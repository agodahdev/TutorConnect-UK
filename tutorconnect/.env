# TutorConnect UK Environment Variables
# IMPORTANT: Never commit this file to git!

# Django Settings
SECRET_KEY=your-super-secret-key-generate-a-new-one
DEBUG=True

# Database (for production - leave empty for development SQLite)
DATABASE_URL=

# Stripe Keys (we'll add these later)
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email Settings (for production)
SENDGRID_API_KEY=
DEFAULT_FROM_EMAIL=noreply@tutorconnect.co.uk

# Allowed Hosts (comma-separated for production)
ALLOWED_HOSTS=localhost,127.0.0.1